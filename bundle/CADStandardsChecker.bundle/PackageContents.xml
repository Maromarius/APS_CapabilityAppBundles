<?xml version="1.0" encoding="utf-8" ?>
<!-- Scaffolded from templates/autocad/PackageContents.xml. Deliberately MINIMAL:
     Version + ProductCode, NO SupportedLocales, both load flags True, Command == [CommandMethod]. -->
<ApplicationPackage SchemaVersion="1.0"
                    Version="1.0"
                    ProductCode="{B06BFE23-461A-4C05-BCBA-0076B4973BD7}"
                    Name="CADStandardsChecker"
                    Description="Validates a DWG against layer naming, text styles, blocks, linetypes, and drawing hygiene rules. Writes report.json, summary.csv, and remediation.md."
                    Author="APS Team">

  <CompanyDetails Name="APS" Url="" Email="" />

  <Components>
    <RuntimeRequirements OS="Win64" Platform="AutoCAD" />
    <ComponentEntry AppName="CADStandardsChecker"
                    ModuleName="./Contents/CADStandardsChecker.dll"
                    AppDescription="CAD Standards Compliance Checker plugin"
                    LoadOnCommandInvocation="True"
                    LoadOnAutoCADStartup="True">
      <Commands GroupName="CADStandardsCheckerCommands">
        <!-- Not "CHECKSTANDARDS" — that is a built-in AutoCAD command that shadows plugins in accoreconsole. -->
        <Command Global="APSCADCHECK" Local="APSCADCHECK" />
      </Commands>
    </ComponentEntry>
  </Components>

</ApplicationPackage>
